# Environment Variables Template
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# ============================================
# Gmail API Credentials
# ============================================
# Get from Google Cloud Console: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080

# ============================================
# Email SMTP Settings (for MCP Email Server)
# ============================================
# For Gmail: Enable 2FA and create App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ============================================
# LinkedIn Credentials
# ============================================
# LinkedIn Developer App: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_USERNAME=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# ============================================
# WhatsApp Settings
# ============================================
# Session path for WhatsApp Web automation
WHATSAPP_SESSION_PATH=./.whatsapp_session

# ============================================
# Bank API Credentials (if applicable)
# ============================================
BANK_API_URL=https://api.yourbank.com
BANK_API_KEY=your_bank_api_key
BANK_ACCOUNT_NUMBER=XXXX-1234

# ============================================
# Odoo ERP Settings (Gold Tier+)
# ============================================
ODOO_URL=http://localhost:8069
ODOO_DATABASE=your_database
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password

# ============================================
# General Settings
# ============================================
# Development mode (prevents real actions)
DEV_MODE=false

# Dry run mode (logs actions without executing)
DRY_RUN=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Security Notes
# ============================================
# 1. Never commit .env file to git
# 2. Rotate credentials monthly
# 3. Use separate credentials for development
# 4. Store backup of credentials securely
# 5. Use environment-specific .env files
